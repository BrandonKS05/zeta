# Required
MODAL_ENDPOINT_URL=https://your-modal-endpoint.modal.run
# Optional: autocomplete-only endpoint. If set, /v1/lean/complete uses this first
# and only falls back to MODAL_ENDPOINT_URL if needed.
MODAL_AUTOCOMPLETE_ENDPOINT_URL=https://aryan-sharma0714--herald-math-grammarly-api.modal.run/

# Optional auth for Modal
MODAL_API_KEY=
# If true, backend rewrites legacy /v1/analyze or /v1/query URLs to /v1/generate.
# Root endpoints (no path) are preserved as-is.
MODAL_USE_GENERATE_ENDPOINT=true

# Runtime
LOG_LEVEL=INFO
MODAL_TIMEOUT_SECONDS=20
MODAL_MAX_RETRIES=2
LEAN_TIMEOUT_SECONDS=15
COMPILER_OUTPUT_MAX_CHARS=20000
INSTALL_LEAN=true

# Lean commands
LEAN_COMMAND=lean
LAKE_COMMAND=lake
ELAN_COMMAND=elan
# Optional: run inside an existing lake project
LAKE_PROJECT_DIR=
# Optional: where temp compile dirs are created (use persistent EC2 disk path if desired)
LEAN_TEMP_DIR=
# Optional: host path mounted by docker-compose for persistent Lean/Lake state
LEAN_STATE_DIR=./.lean-state
# Optional: set ELAN_HOME if you installed Lean toolchains in a custom location
ELAN_HOME=/lean-state/elan
# If true, reject Mathlib imports when LAKE_PROJECT_DIR is not configured
REQUIRE_LAKE_FOR_MATHLIB=true
# If true, auto-run `elan default stable` once when Lean reports no default toolchain
AUTO_CONFIGURE_ELAN_TOOLCHAIN=true
# Default toolchain passed to `elan default <toolchain>`
ELAN_DEFAULT_TOOLCHAIN=stable
# Timeout for automatic `elan default` bootstrap
ELAN_TOOLCHAIN_INSTALL_TIMEOUT_SECONDS=180

# LLM interpretation
ENABLE_LLM_INTERPRETATION=true
ENABLE_LLM_HIGHLIGHTS=true
LLM_ENDPOINT_URL=
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-5-nano
LLM_MAX_COMPLETION_TOKENS=220
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=1
LLM_HIGHLIGHT_TIMEOUT_SECONDS=12
LLM_HIGHLIGHT_MAX_RETRIES=0
AUTOCOMPLETE_LLM_FALLBACK_ENABLED=true
AUTOCOMPLETE_LLM_FALLBACK_MODEL=gpt-5.2
AUTOCOMPLETE_LLM_FALLBACK_TIMEOUT_SECONDS=10
