# Required
MODAL_ENDPOINT_URL=https://your-modal-endpoint.modal.run

# Optional auth for Modal
MODAL_API_KEY=

# Runtime
LOG_LEVEL=INFO
MODAL_TIMEOUT_SECONDS=20
MODAL_MAX_RETRIES=2
LEAN_TIMEOUT_SECONDS=15
COMPILER_OUTPUT_MAX_CHARS=20000
INSTALL_LEAN=true

# Lean commands
LEAN_COMMAND=lean
LAKE_COMMAND=lake
# Optional: run inside an existing lake project
LAKE_PROJECT_DIR=

# LLM interpretation
ENABLE_LLM_INTERPRETATION=true
LLM_ENDPOINT_URL=
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=1
