# Required
MODAL_ENDPOINT_URL=https://your-modal-endpoint.modal.run

# Optional auth for Modal
MODAL_API_KEY=

# Runtime
LOG_LEVEL=INFO
MODAL_TIMEOUT_SECONDS=20
MODAL_MAX_RETRIES=2
LEAN_TIMEOUT_SECONDS=15
COMPILER_OUTPUT_MAX_CHARS=20000
INSTALL_LEAN=true

# Lean commands
LEAN_COMMAND=lean
LAKE_COMMAND=lake
# Optional: run inside an existing lake project
LAKE_PROJECT_DIR=
# Optional: where temp compile dirs are created (use persistent EC2 disk path if desired)
LEAN_TEMP_DIR=
# Optional: host path mounted by docker-compose for persistent Lean/Lake state
LEAN_STATE_DIR=./.lean-state
# Optional: set ELAN_HOME if you installed Lean toolchains in a custom location
ELAN_HOME=
# If true, reject Mathlib imports when LAKE_PROJECT_DIR is not configured
REQUIRE_LAKE_FOR_MATHLIB=true

# LLM interpretation
ENABLE_LLM_INTERPRETATION=true
ENABLE_LLM_HIGHLIGHTS=true
LLM_ENDPOINT_URL=
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=1
LLM_HIGHLIGHT_TIMEOUT_SECONDS=12
LLM_HIGHLIGHT_MAX_RETRIES=0
