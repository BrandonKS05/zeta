HF_TOKEN=hf_xxx
# HF_SECRET_NAME=optional-existing-modal-secret-name

API_KEY=replace-with-random-string
# GRAMMAR_API_SECRET_NAME=optional-existing-modal-secret-name

# For extension / frontend integration:
CORS_ALLOW_ORIGINS=*

# Optional: pin mathlib revision used by on-demand lake project setup.
# MATHLIB_REVISION=<git-sha-or-tag>
# MATHLIB_BOOTSTRAP_TOOLCHAIN=stable
# MATHLIB_PREBUILD_MODULES=Mathlib.Data.Real.Basic,Mathlib.Probability.Filtration,Mathlib.MeasureTheory.Measure.Space,Mathlib.MeasureTheory.MeasurableSpace.Defs
# MATHLIB_BUILD_TIMEOUT_SECONDS=600
# MATHLIB_PREBUILD_STRICT=0
# ENABLE_FINAL_FEEDBACK_LLM=1
# FINAL_FEEDBACK_MAX_NEW_TOKENS=224

# Optional warm pool for lower tail latency.
# GPU_FUNCTION_TIMEOUT_SECONDS=1800
# GPU_MIN_CONTAINERS=1
# GPU_BUFFER_CONTAINERS=1
# GPU_MAX_CONTAINERS=1
# API_MIN_CONTAINERS=1
# API_MAX_CONTAINERS=1

# In-memory cache knobs.
# ANALYZE_CACHE_TTL_SECONDS=600
# ANALYZE_CACHE_MAX_ENTRIES=512
# MODEL_OUTPUT_CACHE_TTL_SECONDS=600
# MODEL_OUTPUT_CACHE_MAX_ENTRIES=512
# LEAN_CHECK_CACHE_TTL_SECONDS=1200
# LEAN_CHECK_CACHE_MAX_ENTRIES=1024
